MONGODB_URI="mongodb+srv://<username>:<password>@<cluster-url>/?appName=Vedryx"
MONGODB_DB="vedryx"

# Apify — used by api/lead-scrape-cron.js (nightly lead pipeline).
# Get from https://console.apify.com/account/integrations
APIFY_TOKEN=""

# Cron auth — shared secret between Vercel Cron and the cron endpoint.
# Vercel sends `Authorization: Bearer $CRON_SECRET` for scheduled invocations.
# Manual debug invocations may pass `x-cron-secret: $CRON_SECRET` instead.
# REQUIRED: lead-scrape-cron.js fails closed (HTTP 503) if this is unset.
CRON_SECRET=""

# USD → INR conversion used by the lead-pipeline cost ledger (soft + hard cap).
# Optional; defaults to 83. Floor enforced at 80 to prevent under-counting spend.
# Update quarterly when FX drifts more than ~5%.
USD_TO_INR=""

# Existing — reporting endpoint token.
LEAD_STATS_TOKEN=""

# Server-side Sentry for Core (no-op when unset).
SENTRY_DSN=""
